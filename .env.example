# DICOM Anonymizer Configuration

# Azure AD / Entra ID SSO Configuration
# Register an App in Entra ID (Azure AD) and configure these values.
# See README.md for setup instructions.
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_REDIRECT_PATH=/auth/callback

# Security Configuration
SECRET_KEY=generate-a-64-character-random-string

# Optional comma-separated list of origins allowed to call the API (e.g. intranet portals)
CORS_ALLOWED_ORIGINS=https://intranet.yourcompany.com,https://another-app.yourcompany.com

# Flask Configuration
FLASK_ENV=production
FLASK_APP=app.py

# Session Configuration (optional)
SESSION_TIMEOUT_MINUTES=60

# Docker Configuration
CONTAINER_NAME=dicom-anonymizer-app
COMPOSE_PROJECT_NAME=docker
APP_PORT=5000
RESTART_POLICY=unless-stopped

# Redis Configuration
REDIS_CONTAINER_NAME=dicom-anonymizer-redis
REDIS_URL=redis://redis:6379/0
REDIS_MEMORY_LIMIT=512M
REDIS_CPU_LIMIT=0.25

# Resource Limits
MEMORY_LIMIT=4G
MEMORY_RESERVATION=512M
CPU_LIMIT=0.6

# Session File Cleanup (minutes before uploaded files are auto-deleted)
SESSION_FILE_TIMEOUT_MINUTES=30
MAX_SESSIONS_PER_USER=3

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=40s

# Python Configuration
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
